# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# IDs created by `npm run setup` — fill these in after running setup
AGENT_ID=agent_...
ENVIRONMENT_ID=env_...
VAULT_ID=vlt_...

# Linear webhook secret (from Linear settings → webhooks)
LINEAR_WEBHOOK_SECRET=your_linear_webhook_secret

# Linear API token (for reading ticket details via custom tool)
LINEAR_API_TOKEN=lin_api_...

# Linear label that triggers the agent (default: "agent").
# Add this label to a ticket to kick off an agent coding session.
LINEAR_AGENT_LABEL=agent

# Fine-grained GitHub PAT scoped to yoshiotu/blueberry
# Permissions: Contents R/W, Pull requests R/W, Metadata R (auto)
# Used for: cloning the repo into the session sandbox (github_repository resource)
GITHUB_TOKEN=github_pat_...

# Same or separate fine-grained PAT for the GitHub Copilot MCP server
# Stored in the vault as a bearer credential; the agent uses it to push branches and open PRs
GITHUB_MCP_TOKEN=github_pat_...

# GitHub webhook signing secret (from the repo's webhook settings).
# Used to verify PR-review webhooks that trigger the review-fix flow.
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
